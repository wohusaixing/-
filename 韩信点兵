#include <stdio.h>
int main()
{
    int i;
    
    for(i = 1;;i++)
    {
        if(i % 5 == 1)
        {
            if(i % 6 == 5)
            {
                if(i % 7 == 4)
                {
                    if(i % 11 == 10)
                    {
                        printf("%d",i);
                        break;
                    }
                }
            }
        }
    }
    return 0;
}
